# Copy to .env.local for local dev, and set these in Vercel → Project Settings.
# NutriCook runs in DEMO MODE (session-only mock data) when the Supabase vars are absent.

# ── Frontend (must be VITE_-prefixed to reach the browser; anon key is public) ──
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Serverless only (NEVER expose to the browser) ──
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=

# ── Stripe (optional; without these, upgrading simulates instantly) ──
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=
